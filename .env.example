# Copy to .env for local development (optional — Flask defaults work without this file)
# cp .env.example .env

# Base URL used in POST /shorten responses (short_url field)
# Local: leave as default or set explicitly
BASE_URL=http://localhost:8080

# --- AWS / deployment (shell exports, not read by Flask) ---
# Get AWS_ACCOUNT_ID from: aws sts get-caller-identity --query Account --output text
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# Built from account + region — used for docker tag and push
# ECR_URI=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/url-shortener

# AWS credentials: configure via `aws configure` (stored in ~/.aws/credentials)
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
